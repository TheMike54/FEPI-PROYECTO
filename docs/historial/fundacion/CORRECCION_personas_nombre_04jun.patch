+  await altaLlenarDatosGenerales(page, { folio, plazo: 60, fechaInicio: '2026-06-01' });
+  await page.getByTestId('btn-siguiente').click();
+  await altaAgregarConcepto(page, 0, { cantidad: 100, pu: 50 });
